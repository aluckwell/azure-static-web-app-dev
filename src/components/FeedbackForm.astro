<form id="feedback-form" class="feedback-form">
  <label>
    Name
    <input
      type="text"
      name="name"
      placeholder="Your name (optional)"
    />
  </label>

  <label>
    Feedback
    <textarea
      name="feedback"
      rows="6"
      placeholder="Tell me what you think..."
      required
    ></textarea>
  </label>

  <button type="submit">
    Send Feedback
  </button>
</form>

<style>
  .feedback-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .feedback-form label {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-weight: 600;
  }

  .feedback-form input,
  .feedback-form textarea {
    padding: 0.75rem;
    border: 1px solid #ccc;
    border-radius: 8px;
    font: inherit;
  }

  .feedback-form textarea {
    resize: vertical;
  }

  .feedback-form button {
    width: fit-content;
    padding: 0.75rem 1.25rem;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font: inherit;
  }
</style>